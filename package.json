{
  "name": "analyitics",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "vp check",
    "fmt": "vp fmt",
    "lint": "vp check",
    "test": "vp run --filter @altitudems/analytics --filter @altitudems/analytics-server test",
    "build": "vp run --filter @altitudems/analytics --filter @altitudems/analytics-server build",
    "dev:api": "vp run --filter @altitudems/example-api dev",
    "dev:demo": "vp run --filter @altitudems/example-demo dev",
    "dev": "vp run --parallel --filter @altitudems/example-api --filter @altitudems/example-demo dev",
    "ready": "vp check && pnpm test && pnpm build",
    "release": "pnpm --filter @altitudems/analytics release"
  },
  "devDependencies": {
    "typescript": "~5.9.3",
    "vite-plus": "0.2.4"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "packageManager": "pnpm@9.15.9"
}
