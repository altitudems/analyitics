{
  "name": "analyitics",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "test:watch": "pnpm --filter @altitudems/analytics test:watch",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "pnpm -r run typecheck",
    "release": "pnpm --filter @altitudems/analytics release"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "typescript": "~5.9.3"
  }
}
