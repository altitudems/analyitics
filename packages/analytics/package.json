{
  "name": "@altitudems/analytics",
  "version": "1.1.0",
  "description": "Browser analytics client for collecting page, click, action, and error events",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/altitudems/analyitics.git",
    "directory": "packages/analytics"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/",
    "access": "restricted"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "release": "semantic-release"
  },
  "dependencies": {
    "@medv/finder": "^4.0.2",
    "bowser": "^2.14.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/node": "^22.15.32",
    "jsdom": "^26.1.0",
    "semantic-release": "^24.2.5",
    "typescript": "~5.9.3",
    "vite": "^6.3.5",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^3.2.4"
  }
}
