{
  "name": "@altitudems/analytics",
  "version": "1.1.0",
  "description": "Browser analytics client for collecting page, click, action, and error events",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/altitudems/analyitics.git",
    "directory": "packages/analytics"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/",
    "access": "restricted"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "release": "semantic-release"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/node": "^22.15.32",
    "happy-dom": "^20.10.6",
    "semantic-release": "^24.2.5",
    "tsdown": "^0.22.8",
    "typescript": "~5.9.3",
    "unrun": "^0.3.1",
    "vitest": "^4.1.10"
  }
}
